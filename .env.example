# PipraPay environment configuration
# Copy this file to ".env" and fill in your values.
#
# When DB_HOST is set below, PipraPay uses these credentials directly and
# SKIPS the setup wizard. This lets you point a fresh deployment at an
# existing PipraPay database (e.g. when moving to a new host) without
# re-running installation.

# --- Database (points to your existing PipraPay database) ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=piprapay
DB_USER=root
DB_PASSWORD=
DB_PREFIX=pp_

# --- Installer switch ---
# true  = allow the setup wizard when no configuration exists (default)
# false = never show the setup wizard; go straight to the login page and
#         use the database configured above.
INSTALLER=false
